{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "blocks",
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shopifyID": {
      "type": "string",
      "required": false
    },
    "categorie": {
      "type": "component",
      "component": "categories.categorie",
      "repeatable": false
    },
    "variants": {
      "type": "component",
      "component": "photos.photo",
      "repeatable": true,
      "required": true
    }
  }
}
